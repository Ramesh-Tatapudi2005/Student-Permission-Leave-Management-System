PORT=

# PostgreSQL Database URL
DATABASE_URL=

SECRET_KEY=
JWT_SECRET=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Supabase File Uploads
SUPABASE_URL=
SUPABASE_KEY=

# ==========================================
# EMAIL & BACKGROUND WORKER SETTINGS
# ==========================================

# Redis URL (Required for Celery to queue the emails & FastAPI Rate Limiting)
REDIS_URL=redis://localhost:6379/0

# SMTP Configuration (For sending emails)
# If using Gmail, you MUST use a 16-character "App Password" here!
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_NAME="Student Permission Center"

# Frontend URL (Used to generate the secure Magic Links for the Faculty)
FRONTEND_URL=http://localhost:5173

# Backend URL (Used to build secure attachment view links embedded in faculty emails)
# In production, set this to your deployed API URL, e.g. https://api.yourdomain.com
BACKEND_URL=http://localhost:8000
